class Solution {
public:
    int minimumLength(string s) {
        int n = s.size();
        int ans = 0;
        int freq[26];

        for (auto i : s) {
            freq[i-'a']++;
        }

        for(auto i : freq) {
            if(i==0)continue;
            if(i%2==0)ans+=2;
            else ans++;
        }
        return ans;
    }
};
