class Solution {
public:
    bool canConstruct(string s, int k) {
        int n = s.size(), count = 0;
        int freq[26];

        if (n<k) {
        return false;
        }

        for(auto i : s) {
            freq[i-'a']++;
        }

        for(auto i : freq) {
            if(i%2!=0)count++;
            if(count>k)return false;
        }
        return true;
    }
};
