class Solution:
    def averageWaitingTime(self, customers: List[List[int]]) -> float:
        ans, total_time = 0, 0
        
        for arr_time, time in customers:
            if total_time < arr_time:
                total_time = arr_time
            
            total_time += time
            ans += total_time - arr_time

        return ans/len(customers)
