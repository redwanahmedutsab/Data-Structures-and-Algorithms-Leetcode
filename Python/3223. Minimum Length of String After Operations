class Solution:
    def minimumLength(self, s: str) -> int:
        freq = [0] * 26
        ans = 0
        for i in s:
            freq[ord(i)-ord('a')] += 1 

        for i in freq:
            if i == 0:
                continue
            if i % 2 == 0:
                ans += 2
            else:
                ans += 1

        return ans
